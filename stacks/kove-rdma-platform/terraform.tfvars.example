# Copy to terraform.tfvars (or use -var-file) and fill in. Do not commit secrets.
#
# Sensitive values (RHSM): for Terraform CLI, copy secrets.auto.tfvars.example →
# secrets.auto.tfvars (Terraform loads *.auto.tfvars). For OCI Resource Manager,
# set **RHSM organization ID** and **RHSM activation key** in the stack variables UI
# (same Terraform variables: rhsm_org_id, rhsm_activation_key).

tenancy_ocid     = "ocid1.tenancy.oc1..aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
region           = "us-phoenix-1"
compartment_ocid = "ocid1.compartment.oc1..aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"

# Optional: tenancy home region when it differs from `region` (IAM / cross-region cases).
# identity_home_region = "us-phoenix-1"

ssh_public_key = "ssh-ed25519 AAAA...your-key... comment"

# Naming (modules/labels) — display prefix = kove_environment-kove_stack_name with namespace
kove_namespace   = "kove"
kove_environment = "dev"
kove_stack_name  = "rdma"

tags = {
  project = "rdma-platform"
}

# New VCN (default): 10.0.1.0/24 public, 10.0.2.0/24 mgmt, 10.0.3.0/24 RDMA
# use_existing_vcn = false
# When creating the VCN (oracle-quickstart/oci-hpc style: NAT + service gateway, DHCP VcnLocalPlusInternet):
# ssh_ingress_cidr = "203.0.113.0/24"
# public_ingress_hpc_ui_ports = false

# Or use three existing subnets (+ VCN OCID):
# use_existing_vcn              = true
# existing_vcn_id               = "ocid1.vcn.oc1..aaaa"
# existing_public_subnet_id     = "ocid1.subnet.oc1..aaaa"
# existing_management_subnet_id = "ocid1.subnet.oc1..aaaa"
# existing_rdma_subnet_id       = "ocid1.subnet.oc1..aaaa"

# Pin AD if needed (otherwise derived from RDMA subnet, then mgmt, then public, then first tenancy AD):
# availability_domain = "pILZ:PHX-AD-2"

# Bare metal custom image (control + all memory nodes)
bm_node_image_ocid = "ocid1.image.oc1..aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"

# RDMA placement mode:
# - compute_cluster: current behavior (individual BM instances in an OCI compute cluster)
# - cluster_network: OCI cluster network instance pool (supports Terraform-driven resize/autoscale)
# rdma_deployment_mode = "compute_cluster"

# Scale memory nodes (control is always 1). Default 2 → 3 BM instances total.
memory_node_count = 2
# Role naming for RDMA plane
# compute_system_name = "compute-system"
# xpd_name            = "xpd"

# Bare metal plane (matches Resource Manager group "Bare metal (RDMA plane)")
# bm_node_shape                  = "BM.Optimized3.36"
# bm_boot_volume_size_gbs        = 120
# bm_generic_platform_config     = false
# bm_smt_enabled                 = true
# bm_numa_nodes_per_socket       = "NPS1"
# use_compute_agent              = false
# bm_imds_ssh_key_bootstrap      = true
# bm_capacity_reservation_id     = ""
# cluster_network_create_timeout = "2h"

# OCI Cluster Placement Group for BM rack-aware placement (creates before instances via implicit dependency)
# cluster_placement_group_enabled     = true
# cluster_placement_group_type        = "STANDARD"
# cluster_placement_group_name        = ""
# cluster_placement_group_description = ""

# Optional bastion / management shapes (defaults: VM.Standard.E6.Flex, 2 OCPU, 16 GB)
# enable_bastion = true
# bastion_shape          = "VM.Standard.E6.Flex"
# bastion_ocpus          = 2
# bastion_memory_gbs     = 16
# bastion_image_ocid     = ""
# management_shape       = "VM.Standard.E6.Flex"
# management_ocpus       = 2
# management_memory_gbs  = 16
# management_image_ocid  = ""
# management_secondary_vnic_enabled    = false
# management_secondary_vnic_subnet_id  = "" # empty => rdma subnet
# management_secondary_vnic_private_ip = "" # optional static IP

# RHSM for cloud-init (prefer secrets.auto.tfvars for CLI). Resource Manager: use stack variables.
# rhsm_org_id           = "your-rhsm-org-id"
# rhsm_activation_key   = "your-activation-key"
# playbooks_zip_url     = "https://objectstorage.region.oraclecloud.com/.../playbooks.zip"

# Serial console over SSH tunnel (optional)
# create_bm_console_connections = false

# Optional dedicated MC host VM (separate from RDMA BM plane)
# enable_mc_instance = true
# mc_shape               = "VM.Standard3.Flex"
# mc_ocpus               = 3
# mc_memory_gbs          = 32
# mc_boot_volume_size_gbs = 200
# mc_assign_public_ip    = false
# mc_subnet_id           = "" # empty => management subnet from this stack
# mc_availability_domain = "" # empty => same AD resolved by this stack
#
# Cloud-init runs in both modes.
#
# Option 1: use custom image for host OS baseline
# mc_deployment_mode     = "custom_image"
# mc_custom_image_ocid   = "ocid1.image.oc1..aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
#
# Option 2: run KVM host prep by cloud-init, then manually copy OVA and run setup script
# mc_deployment_mode          = "cloud_init_setup"
# mc_base_image_ocid          = "" # empty => latest Oracle Linux 8 compatible with mc_shape
# mc_cloud_init_template_path = ""
# mc_setup_script_path        = "/opt/kove/setup-kove-mc.sh"
# mc_guest_vm_name            = "kove-mc"
# mc_guest_disk_path          = "/var/lib/libvirt/images/kove-mc.qcow2"
# mc_guest_vcpus              = 2
# mc_guest_memory_mb          = 8192

# Autoscaling is no longer configured in this stack.
# Use modules/rdma-autoscale for OCI Function + alarm autoscaling.
