# Recommended template: existing VCN + cluster_network + bastion + MC/management.
# Copy to terraform.tfvars or use -var-file. Do not commit secrets.

tenancy_ocid     = "ocid1.tenancy.oc1..REPLACE_ME"
region           = "eu-frankfurt-1"
compartment_ocid = "ocid1.compartment.oc1..REPLACE_ME"

ssh_public_key = <<-EOT
ssh-rsa REPLACE_ME
EOT

kove_namespace        = "kove"
kove_environment      = "prod"
# Set true after the OCI defined-tag namespace and keys are created.
enable_defined_tags   = false
defined_tag_namespace = "kove"

tags = {
  workload = "rdma-platform"
}

# Example: pILZ:EU-FRANKFURT-1-AD-2
availability_domain = "REPLACE_ME"

use_existing_vcn           = true
existing_vcn_id            = "ocid1.vcn.oc1.eu-frankfurt-1.REPLACE_ME"
existing_public_subnet_id  = "ocid1.subnet.oc1.eu-frankfurt-1.REPLACE_ME"
existing_private_subnet_id = "ocid1.subnet.oc1.eu-frankfurt-1.REPLACE_ME"

# Images: one shared RHEL 8.10 base image, with optional per-role overrides.
rhel8_10_image_ocid        = "ocid1.image.oc1.eu-frankfurt-1.REPLACE_ME"
bm_node_custom_image_ocid  = ""
mc_custom_image_ocid       = ""
bastion_custom_image_ocid  = ""

# RDMA memory-node infrastructure.
rdma_deployment_mode = "cluster_network"
memory_node_count    = 2
xpd_name             = "xpd"

# Optional compute-system BM. Disable this without affecting memory nodes.
enable_compute_system = true
compute_system_name   = "compute-system"

# Optional: switch compute-system from single-BM mode to dedicated
# cluster-network + instance-pool mode.
# compute_system_use_cluster_network_autoscaling = true
# compute_system_cluster_network_node_count = 1
# compute_system_cluster_network_enable_autoscaling = false
# compute_system_cluster_network_autoscaling_min_nodes = 1
# compute_system_cluster_network_autoscaling_max_nodes = 4
# compute_system_cluster_network_autoscaling_initial_nodes = 1
# compute_system_cluster_network_autoscaling_cooldown_seconds = 300
# compute_system_cluster_network_autoscaling_scale_out_threshold_percent = 75  # CPU%
# compute_system_cluster_network_autoscaling_scale_in_threshold_percent = 30   # CPU%
# compute_system_cluster_network_autoscaling_scale_out_by = 1
# compute_system_cluster_network_autoscaling_scale_in_by = 1

# Optional RDMA cluster placement group (xpd-cluster).
# WARNING: can reduce placement flexibility and increase capacity-related launch failures in constrained AD/FD conditions.
# cluster_placement_group_enabled     = true
# cluster_placement_group_type        = "STANDARD"
# cluster_placement_group_name        = "kove-rdma-cpg"
# cluster_placement_group_description = "RDMA bare metal placement group"

# Cluster-network autoscaling.
cluster_network_enable_autoscaling                      = true
cluster_network_autoscaling_min_nodes                   = 2
cluster_network_autoscaling_max_nodes                   = 8
cluster_network_autoscaling_initial_nodes               = 2
cluster_network_autoscaling_cooldown_seconds            = 300
cluster_network_autoscaling_scale_out_threshold_percent = 80
cluster_network_autoscaling_scale_in_threshold_percent  = 30
cluster_network_autoscaling_scale_out_by                = 1
cluster_network_autoscaling_scale_in_by                 = 1

use_compute_agent              = true
bm_generic_platform_config     = false
bm_capacity_reservation_id     = ""
bm_boot_volume_size_gbs        = 120
cluster_network_create_timeout = "2h"
bm_imds_ssh_key_bootstrap      = true
create_bm_console_connections  = false

# Bastion jump host.
enable_bastion = true

# MC instance. This is the management VM.
enable_mc_instance  = true
mc_shape            = "VM.Standard3.Flex"
mc_ocpus            = 3
mc_memory_gbs       = 32
mc_assign_public_ip = false

# MC KVM host automation toggle (default false):
# - false: use docs/mc-setup-manual-end-to-end.md
# - true : cloud-init configures KVM/libvirt helpers automatically
mc_enable_kvm_automation = false

# MC deployment mode.
mc_deployment_mode = "custom_image"

# Alternate mode for building MC host dependencies with cloud-init.
# mc_deployment_mode = "cloud_init_setup"

# RHSM values for cloud-init based flows.
# rhsm_org_id         = "REPLACE_ME"
# rhsm_activation_key = "REPLACE_ME"

# Offline RPM repo tarballs for cloud-init based flows.
# offline_repo_tarball_url    = "https://objectstorage.REGION.oraclecloud.com/p/REPLACE_ME/n/NAMESPACE/b/BUCKET/o/kove-rhel8.10-offline-rpms.tar.gz"
# offline_repo_tarball_sha256 = "REPLACE_ME"
# mc_offline_repo_tarball_url    = "https://objectstorage.REGION.oraclecloud.com/p/REPLACE_ME/n/NAMESPACE/b/BUCKET/o/kove-rhel8.10-offline-rpms.tar.gz"
# mc_offline_repo_tarball_sha256 = "REPLACE_ME"
