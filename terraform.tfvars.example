# Recommended template: existing VCN + cluster_network + bastion + MC host (Frankfurt-style)
# Copy to terraform.tfvars (or use -var-file) and fill placeholders. Do not commit secrets.

tenancy_ocid     = "ocid1.tenancy.oc1..REPLACE_ME"
region           = "eu-frankfurt-1"
compartment_ocid = "ocid1.compartment.oc1..REPLACE_ME"

ssh_public_key = <<-EOT
ssh-rsa REPLACE_ME
EOT

kove_namespace    = "kove"
kove_environment  = "prod"
kove_stack_name   = "rdma"
host_label_prefix = "fra"

tags = {
  project = "rdma-platform"
  env     = "prod"
}

# Example: pILZ:EU-FRANKFURT-1-AD-2
availability_domain = "REPLACE_ME"

use_existing_vcn              = true
existing_vcn_id               = "ocid1.vcn.oc1.eu-frankfurt-1.REPLACE_ME"
existing_public_subnet_id     = "ocid1.subnet.oc1.eu-frankfurt-1.REPLACE_ME"
existing_management_subnet_id = "ocid1.subnet.oc1.eu-frankfurt-1.REPLACE_ME"
existing_rdma_subnet_id       = "ocid1.subnet.oc1.eu-frankfurt-1.REPLACE_ME"

# RDMA / BM plane
bm_node_image_ocid   = "ocid1.image.oc1.eu-frankfurt-1.REPLACE_ME"
rdma_deployment_mode = "cluster_network"
memory_node_count    = 2

# Cluster-network autoscaling (memory metric)
cluster_network_enable_autoscaling                      = true
cluster_network_autoscaling_min_nodes                   = 2
cluster_network_autoscaling_max_nodes                   = 8
cluster_network_autoscaling_initial_nodes               = 2
cluster_network_autoscaling_cooldown_seconds            = 300
cluster_network_autoscaling_scale_out_threshold_percent = 80
cluster_network_autoscaling_scale_in_threshold_percent  = 30
cluster_network_autoscaling_scale_out_by                = 1
cluster_network_autoscaling_scale_in_by                 = 1

use_compute_agent              = true
bm_generic_platform_config     = false
bm_capacity_reservation_id     = ""
bm_boot_volume_size_gbs        = 120
cluster_network_create_timeout = "2h"
bm_imds_ssh_key_bootstrap      = true
create_bm_console_connections  = false

# Role naming
compute_system_name = "compute-system"
xpd_name            = "xpd"

# Bastion
enable_bastion = true

# MC host (separate instance)
enable_management_instance  = false
enable_mc_instance          = true
mc_shape                    = "VM.Standard3.Flex"
mc_ocpus                    = 3
mc_memory_gbs               = 32
mc_assign_public_ip         = false
mc_subnet_id                = "ocid1.subnet.oc1.eu-frankfurt-1.REPLACE_ME"

# Optional secondary VNIC controls
# mc_secondary_vnic_subnet_id = "ocid1.subnet.oc1.eu-frankfurt-1.REPLACE_ME"
# mc_secondary_vnic_private_ip = "10.0.2.58"
mc_secondary_vnic_interface = "eth1"

# MC deployment mode (recommended)
mc_deployment_mode   = "custom_image"
mc_custom_image_ocid = "ocid1.image.oc1.eu-frankfurt-1.REPLACE_ME"

# Alternate mode (optional advanced path)
# mc_deployment_mode = "cloud_init_setup"
# mc_base_image_ocid = "ocid1.image.oc1.eu-frankfurt-1.REPLACE_ME"

# RHSM values for cloud-init based flows
# Conditionally required: set both when your image/bootstrap needs RHSM-entitled RHEL repos.
# If your custom image is already pre-entitled (or doesn't need RHSM), these can stay unset.
# rhsm_org_id         = "REPLACE_ME"
# rhsm_activation_key = "REPLACE_ME"
